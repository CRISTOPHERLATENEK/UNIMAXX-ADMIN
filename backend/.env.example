# Ambiente
NODE_ENV=development

# Porta do servidor
PORT=3001

# JWT Secret (obrigatório em produção — use uma string longa e aleatória)
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<gere-uma-chave-segura-aqui>

# CORS Origins (separados por vírgula — obrigatório em produção)
# Ex.: https://seudominio.com,https://www.seudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Caminho do banco SQLite
# Ex.: DB_PATH=/home/SEU_USUARIO/storage/database.sqlite
DB_PATH=./database.sqlite

# Pasta de uploads
# Ex.: UPLOAD_DIR=/home/SEU_USUARIO/storage/uploads
UPLOAD_DIR=./uploads

# Seed do admin (defina true apenas uma vez em produção, depois desative)
SEED_ADMIN=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<senha-forte-minimo-12-caracteres>
ADMIN_NAME=Admin
